# ── Veris environment ───────────────────────────────────────────────
# Copy to .env and fill in. Never commit .env.
# The backend reads .env from the repo root OR from backend/ — either works.

# Application
VERIS_ENV=development                 # development | production
VERIS_LOG_LEVEL=INFO
VERIS_API_HOST=0.0.0.0
VERIS_API_PORT=8000
VERIS_CORS_ORIGINS=http://localhost:3000

# Database (Postgres + pgvector). In development the backend uses local SQLite regardless,
# so you can leave this as-is until you run the Docker/Postgres stack.
VERIS_DATABASE_URL=postgresql+asyncpg://veris:veris@localhost:5432/veris


# LLM provider selection: auto | anthropic | hf | stub
#   auto → Claude if ANTHROPIC_API_KEY is set, else the Hugging Face router if HF_TOKEN
#   is set, else the deterministic stub (keeps everything runnable with no key).
VERIS_LLM_PROVIDER=auto

# Route A — Claude (Anthropic).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VERIS_SYNTHESIS_MODEL=claude-sonnet-5
VERIS_UTILITY_MODEL=claude-haiku-4-5-20251001

# Route B — free/open models via any OpenAI-compatible endpoint (HF Inference Providers
# by default; Groq/Together/OpenRouter/vLLM also work by changing the base URL).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VERIS_LLM_BASE_URL=https://router.huggingface.co/v1
VERIS_OSS_SYNTHESIS_MODEL=meta-llama/Llama-3.3-70B-Instruct
VERIS_OSS_UTILITY_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Embeddings (local ONNX via fastembed). Use "hashing" for a zero-download dev embedder.
VERIS_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
VERIS_RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# Retrieval tuning
VERIS_DENSE_TOP_K=40
VERIS_SPARSE_TOP_K=40
VERIS_RERANK_TOP_K=12
VERIS_RRF_K=60

# Ingestion
VERIS_ARXIV_API_URL=https://export.arxiv.org/api/query
VERIS_INGEST_BATCH_SIZE=50

# Boot seeding (for ephemeral-disk deploys): when set and the corpus is empty at
# startup, these topics are ingested in the background and the map is prebuilt.
# VERIS_SEED_TOPICS=retrieval augmented generation,diffusion models
# VERIS_SEED_MAX_PER_TOPIC=20
