# ── Veris environment ───────────────────────────────────────────────
# Copy to .env and fill in. Never commit .env.
# The backend reads .env from the repo root OR from backend/ — either works.

# Application
VERIS_ENV=development                 # development | production
VERIS_LOG_LEVEL=INFO
VERIS_API_HOST=0.0.0.0
VERIS_API_PORT=8000
VERIS_CORS_ORIGINS=http://localhost:3000

# Database (Postgres + pgvector). In development the backend uses local SQLite regardless,
# so you can leave this as-is until you run the Docker/Postgres stack.
VERIS_DATABASE_URL=postgresql+asyncpg://veris:veris@localhost:5432/veris


# LLM — Claude (Anthropic). Set this to enable real synthesis; without it the deterministic
# stub provider keeps everything runnable.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VERIS_SYNTHESIS_MODEL=claude-sonnet-5
VERIS_UTILITY_MODEL=claude-haiku-4-5-20251001

# Embeddings (local ONNX via fastembed). Use "hashing" for a zero-download dev embedder.
VERIS_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
VERIS_RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# Retrieval tuning
VERIS_DENSE_TOP_K=40
VERIS_SPARSE_TOP_K=40
VERIS_RERANK_TOP_K=12
VERIS_RRF_K=60

# Ingestion
VERIS_ARXIV_API_URL=https://export.arxiv.org/api/query
VERIS_INGEST_BATCH_SIZE=50
